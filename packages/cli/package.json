{
  "name": "@relay/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the Relay review platform",
  "type": "module",
  "bin": {
    "relay": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": {
      "import": "./dist/cli.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@relay/core": "workspace:*",
    "@relay/reporters": "workspace:*",
    "@relay/shared": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.2.3"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
