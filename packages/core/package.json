{
  "name": "@relay/core",
  "version": "0.1.0",
  "description": "Transport-agnostic review engine for the Relay platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@relay/shared": "workspace:*",
    "@relay/rules-security": "workspace:*",
    "@relay/rules-accessibility": "workspace:*",
    "@relay/rules-performance": "workspace:*",
    "@relay/rules-testing": "workspace:*",
    "@relay/rules-architecture": "workspace:*",
    "@relay/rules-deployment": "workspace:*",
    "@relay/rules-documentation": "workspace:*",
    "c12": "^2.0.1",
    "consola": "^3.2.3",
    "fast-glob": "^3.3.2",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
