{
  "name": "@relay/reporters",
  "version": "0.1.0",
  "description": "Report renderers for the Relay platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./terminal": {
      "import": "./dist/terminal/index.js",
      "types": "./dist/terminal/index.d.ts"
    },
    "./json": {
      "import": "./dist/json/index.js",
      "types": "./dist/json/index.d.ts"
    },
    "./markdown": {
      "import": "./dist/markdown/index.js",
      "types": "./dist/markdown/index.d.ts"
    },
    "./sarif": {
      "import": "./dist/sarif/index.js",
      "types": "./dist/sarif/index.d.ts"
    },
    "./html": {
      "import": "./dist/html/index.js",
      "types": "./dist/html/index.d.ts"
    },
    "./github": {
      "import": "./dist/github/index.js",
      "types": "./dist/github/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@relay/shared": "workspace:*",
    "chalk": "^5.3.0",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
